##            User Secrets            ##
######################################
# Хранилище секретов для локальной разработки
# (чтобы случайно не закоммитить пароли и ключи)
secrets.json

##         Entity Framework Core      ##
######################################
# Игнорируем логи миграций, если они генерируются инструментами
*.migrations.id

##               SQLite               ##
######################################
# Игнорируем саму базу данных (обычно вы хотите, чтобы она создавалась кодом через migrations/EnsureCreated)
*.db
*.sqlite
*.sqlite3

# Игнорируем временные файлы журналов SQLite (journal и Write-Ahead Log)
*.db-journal
*.db-shm
*.db-wal
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

##            Окружение               ##
######################################
# Игнорируем файлы конфигурации содержащие реальные секреты prod/stage
appsettings.Development.json
# ПРИМЕЧАНИЕ: Оставьте appsettings.json в репозитории как шаблон (без реальных паролей)

